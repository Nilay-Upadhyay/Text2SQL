# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-120b

# Database Configuration (using DATABASE_URL or individual variables)
# Option 1: Single connection string
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/database_name

# Option 2: Individual variables (used if DATABASE_URL not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=database_name
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Dynamic Schema Retrieval Configuration (PGVector)
# Enable/disable dynamic schema retrieval (default: true)
USE_DYNAMIC_SCHEMA=true

# Minimum confidence score for using retrieved schema (0-1)
# Lower values = more aggressive filtering, higher = more conservative
# Recommended: 0.2-0.5
SCHEMA_CONFIDENCE_THRESHOLD=0.2

